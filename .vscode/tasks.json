{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: configure",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/cmake-msvc-env.cmd",
      "args": ["--preset", "default"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "CMake: build",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/cmake-msvc-env.cmd",
      "args": ["--build", "--preset", "default"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "CMake: configure",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc"
    }
  ]
}
