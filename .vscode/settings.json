{
  "cmake.useCMakePresets": "always",
  "cmake.configureOnOpen": false,
  "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
  "C_Cpp.default.cppStandard": "c++17",
  "C_Cpp.default.compileCommands": "${workspaceFolder}/build/default/compile_commands.json",
  "C_Cpp.default.includePath": [
    "${workspaceFolder}/src",
    "${workspaceFolder}/3rd_party/glfw-src/include",
    "${workspaceFolder}/3rd_party/glm-src",
    "${workspaceFolder}/3rd_party/stb-src",
    "${workspaceFolder}/3rd_party/imgui-src",
    "${workspaceFolder}/3rd_party/imgui-src/backends",
    "${workspaceFolder}/3rd_party/nlohmann_json-src/include",
    "${workspaceFolder}/build/default/gladsources/glad_gl_core_33/include"
  ],
  "C_Cpp.default.defines": [
    "GLFW_INCLUDE_NONE",
    "IMGUI_IMPL_OPENGL_LOADER_GLAD"
  ],
  "C_Cpp.files.exclude": {
    "**/3rd_party/**": true
  },
  "java.import.exclusions": [
    "**/3rd_party/**"
  ],
  "java.import.gradle.enabled": false,
  "files.watcherExclude": {
    "**/3rd_party/**": true
  },
  "search.exclude": {
    "**/3rd_party/**": true
  }
}
